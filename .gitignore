# Dependencies (any level)
node_modules/
.pnp/
.pnp.js

# Build output
dist/
build/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment + credentials
# .env variants
.env
.env.local
.env.*.local

# pi auth + credential stores (in case any are ever copied into the repo)
# User-global: ~/.pi/agent/auth.json (API keys + OAuth tokens)
# Models config that may include inline keys: ~/.pi/agent/models.json
# Keybindings: ~/.pi/agent/keybindings.json (no creds, but per-user)
auth.json
models.json
keybindings.json
credentials.json
secrets.json
*.pem
*.key
*.p12
*.pfx

# Catch-all for any JSON/YAML/ENV files that look like they hold secrets
# (only the basename, not arbitrary *.json — many of those are legitimate)
*credentials*.json
*credentials*.yaml
*credentials*.yml
*credentials*.toml
*secrets*.json
*secrets*.yaml
*secrets*.yml
*secrets*.toml

# Misc
.bak/
.old/
test/
tests/
.dockerignore
docs/
rules.md
dev.md
skills/cache-audit/SKILL.old
AGENTS.md

# Archived skills
skills/*.rar

# pi package cache (global and project-local)
.pi/

# Extension runtime data (created lazily by the extension from in-code
# defaults on first use). Contains user settings, SSH credentials and usage
# history. NEVER commit any of it: ignore the whole directory, with no
# negation rules. See AGENTS.md "Data directory, packaging, and
# test-exclusion decisions (permanent)".
.pi-aftc-toolset/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Release notes are NOT kept as files — the root README.md is the source of truth.
# (rules.md Section 10.4) Do not add RELEASE_NOTES_*.md to the repo.

*.pyc
.venv/
__pycache__/
tests/
