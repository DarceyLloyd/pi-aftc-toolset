# Dependencies (any level)
node_modules/
.pnp/
.pnp.js

# Build output
dist/
build/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment + credentials
# .env variants
.env
.env.local
.env.*.local

# pi auth + credential stores (in case any are ever copied into the repo)
# User-global: ~/.pi/agent/auth.json (API keys + OAuth tokens)
# Models config that may include inline keys: ~/.pi/agent/models.json
# Keybindings: ~/.pi/agent/keybindings.json (no creds, but per-user)
auth.json
models.json
keybindings.json
credentials.json
secrets.json
*.pem
*.key
*.p12
*.pfx

# Catch-all for any JSON/YAML/ENV files that look like they hold secrets
# (only the basename, not arbitrary *.json — many of those are legitimate)
*credentials*.json
*credentials*.yaml
*credentials*.yml
*credentials*.toml
*secrets*.json
*secrets*.yaml
*secrets*.yml
*secrets*.toml

# Misc
.bak/
.old/
test/
rules.md
dev.md
skills/cache-audit/SKILL.old

# Archived skills
skills/*.rar

# pi package cache (global and project-local)
.pi/

# Cache-optimizer data folder (created on first use; per-user, not in repo)
.pi-aftc-toolset/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Release notes are NOT kept as files — the root README.md is the source of truth.
# (rules.md Section 10.4) Do not add RELEASE_NOTES_*.md to the repo.

# Python (AFTC SSH GUI)
# .venv/ = runtime venv (never commit — huge + system-specific)
# std/*  = SSH session logs, credentials, command history (SECURITY: never commit)
# std/.gitkeep = preserved so the directory exists on clone
# bin/uv.exe = tracked (bundled so users don't need Python or uv on PATH)
internal-python-gui/.venv/
internal-python-gui/__pycache__/
internal-python-gui/std/*
!internal-python-gui/std/.gitkeep
*.pyc
tests/
